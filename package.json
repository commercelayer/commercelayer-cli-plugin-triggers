{
  "name": "@commercelayer/cli-plugin-triggers",
  "description": "Commerce Layer CLI Triggers plugin",
  "version": "4.7.1",
  "author": "Pierluigi Viti <pierluigi@commercelayer.io>",
  "homepage": "https://github.com/commercelayer/commercelayer-cli-plugin-triggers",
  "repository": "commercelayer/commercelayer-cli-plugin-triggers",
  "bugs": "https://github.com/commercelayer/commercelayer-cli-plugin-triggers/issues",
  "engines": {
    "node": ">=22"
  },
  "files": [
    "/bin/run.*",
    "/lib",
    "/npm-shrinkwrap.json",
    "/oclif.manifest.json"
  ],
  "keywords": [
    "ecommerce",
    "cli",
    "commercelayer"
  ],
  "license": "MIT",
  "main": "lib/index.js",
  "oclif": {
    "commands": "./lib/commands",
    "bin": "cl-triggers",
    "devPlugins": [
      "@oclif/plugin-help"
    ],
    "plugins": [],
    "topics": {
      "triggers": {
        "description": "Execute resource triggers",
        "hidden": true
      }
    },
    "repositoryPrefix": "<%- repo %>/blob/main/<%- commandPath %>",
    "additionalHelpFlags": [
      "-h"
    ],
    "topicSeparator": ":"
  },
  "scripts": {
    "prepack": "pnpm generate && pnpm build && oclif manifest && pnpm readme",
    "build": "rm -rf lib && tsc -b",
    "postpack": "rm -f oclif.manifest.json",
    "test": "nyc --extension .ts mocha --forbid-only \"test/**/*.test.ts\"",
    "posttest": "pnpm lint",
    "readme": "cl-cli-dev readme --plugin --bin=commercelayer && git add README.md",
    "generate": "tsx gen/generator.ts",
    "lint": "biome check --enforce-assist=true",
		"check": "biome check --enforce-assist=true --write",
		"release": "pnpm upgrade && pnpm prepack && pnpm postpack && pnpm test"
  },
  "types": "lib/index.d.ts",
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@commercelayer/cli-dev": "oclif4",
    "@oclif/plugin-help": "^6.2.40",
    "@oclif/test": "^4.1.17",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/chai": "^5.2.3",
    "@types/inquirer": "^8.2.12",
    "@types/lodash.snakecase": "^4.1.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.0",
    "chai": "^6.2.2",
    "inflector-js": "^1.0.1",
    "lodash.snakecase": "^4.1.1",
    "mocha": "^11.7.5",
    "nyc": "^18.0.0",
    "oclif": "^4.22.96",
    "semantic-release": "^25.0.3",
    "tsx": "^4.21.0",
    "typescript": "6.0.2"
  },
  "dependencies": {
    "@commercelayer/cli-core": "oclif4",
    "@commercelayer/sdk": "^6.55.0",
    "@oclif/core": "^4.10.3",
    "inquirer": "^8.2.7",
    "tslib": "^2.8.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
